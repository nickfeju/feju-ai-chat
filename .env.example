# Gebruik bij voorkeur een API-endpoint zonder Function key in de URL.
VITE_FUNCTION_URL=https://<jouw-function-app>.azurewebsites.net/api/ask

# Optioneel: eigen Entra API-scope, bijvoorbeeld api://<api-client-id>/access_as_user.
# Wanneer leeg, stuurt de frontend geen Bearer-token naar de Function.
VITE_API_SCOPE=

VITE_ENTRA_CLIENT_ID=59c65b43-60e0-4c9f-87f9-4a005a51fa54
VITE_ENTRA_TENANT_ID=d8e80c75-af0c-4d17-a7a5-4849d64af1c5
VITE_REQUEST_TIMEOUT_MS=60000
VITE_CONVERSATION_LIMIT=8
